rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // Bootstrapped admin from runtime metadata
      return isSignedIn() && (
        request.auth.token.email == "05220010.jnec@rub.edu.bt" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // --- Validation Helpers ---

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'carbonCredits', 'totalEmissions', 'joinedAt']) &&
             data.keys().size() == 6 &&
             data.uid == request.auth.uid &&
             data.role in ['industry', 'admin', 'investor'] &&
             data.carbonCredits is number &&
             data.totalEmissions is number &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidSensorData(data) {
      return data.keys().hasAll(['deviceId', 'industryId', 'mq2', 'mq3', 'timestamp']) &&
             data.keys().size() == 5 &&
             data.industryId == request.auth.uid &&
             data.mq2 is number &&
             data.mq3 is number &&
             data.timestamp == request.time;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['fromId', 'toId', 'amount', 'pricePerCredit', 'totalPrice', 'type', 'status', 'timestamp']) &&
             data.keys().size() == 8 &&
             (data.fromId == request.auth.uid || data.toId == request.auth.uid) &&
             data.amount is number &&
             data.pricePerCredit is number &&
             data.type in ['buy', 'sell'] &&
             data.status in ['pending', 'completed', 'cancelled'];
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isVerified() && isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isVerified() && isOwner(userId) && isValidUserProfile(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'industryType', 'carbonCredits', 'totalEmissions'])
      ) || isAdmin();
    }

    match /emissions/{emissionId} {
      allow read: if isSignedIn() && (existing().industryId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidSensorData(incoming());
      allow delete: if isAdmin();
    }

    match /marketplace/{transactionId} {
      allow read: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isVerified() && isValidTransaction(incoming());
      allow update: if isVerified() && (incoming().fromId == request.auth.uid || incoming().toId == request.auth.uid) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                    incoming().status in ['completed', 'cancelled'];
    }

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
